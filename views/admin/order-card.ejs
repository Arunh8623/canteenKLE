<%
  var ns, nl, nc;
  if      (order.status === 'pending')   { ns='preparing'; nl='Start Preparing'; nc='bg-blue-600 hover:bg-blue-700';  }
  else if (order.status === 'preparing') { ns='ready';     nl='Mark Ready';      nc='bg-green-600 hover:bg-green-700';}
  else if (order.status === 'ready')     { ns='delivered'; nl='Mark Delivered';  nc='bg-gray-600 hover:bg-gray-700';  }
  else                                   { ns='';          nl='Completed';        nc='bg-gray-700';                    }

  var shortId     = order.uuid ? order.uuid.slice(0,8).toUpperCase() : String(order.id);
  var orderTime   = order.created_at ? new Date(order.created_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '';
  var amount      = parseFloat(order.total_amount||0).toFixed(0);
  var isPriority  = order.priority === 'high';
  var isLecturer  = order.user_role === 'lecturer';
  var isReady     = order.status === 'ready';
  var hasPhone    = !!order.user_phone;
  var hasNote     = !!order.special_note;
%>

<div class="bg-gray-900 border border-gray-800 rounded-2xl p-4 hover:border-gray-700 transition-colors" id="order-<%= order.id %>">

  <!-- Header -->
  <div class="flex items-center justify-between mb-3">
    <div>
      <div class="flex items-center gap-2">
        <span class="font-mono font-bold text-white text-sm">#<%= shortId %></span>
        <% if (isPriority) { %>
          <span class="bg-purple-500/20 text-purple-400 text-[10px] font-bold px-1.5 py-0.5 rounded-full">
            <i class="fa-solid fa-star text-[8px]"></i> PRIORITY
          </span>
        <% } %>
      </div>
      <p class="text-xs text-gray-400 mt-0.5"><%= orderTime %></p>
    </div>
    <span class="font-bold text-orange-400">&#8377;<%= amount %></span>
  </div>

  <!-- Customer -->
  <div class="bg-gray-800 rounded-xl px-3 py-2.5 mb-3">
    <div class="flex items-center gap-2">
      <div class="w-6 h-6 bg-orange-500/20 rounded-full flex items-center justify-center flex-shrink-0">
        <i class="fa-solid fa-user text-orange-400 text-[10px]"></i>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-medium text-white truncate"><%= order.user_name || 'Unknown' %></p>
        <p class="text-xs text-gray-400 truncate"><%= order.user_phone || 'No phone' %></p>
      </div>
      <% if (isLecturer) { %>
        <span class="ml-auto text-[10px] bg-purple-500/20 text-purple-400 px-1.5 py-0.5 rounded font-semibold flex-shrink-0">Staff</span>
      <% } %>
    </div>
  </div>

  <!-- Items -->
  <div class="space-y-1 mb-3">
    <% (order.items || []).forEach(function(item) { %>
      <div class="flex justify-between text-xs text-gray-400">
        <span class="truncate"><%= item.item_name %></span>
        <span class="ml-2 flex-shrink-0">x<%= item.quantity %></span>
      </div>
    <% }); %>
  </div>

  <!-- Note -->
  <% if (hasNote) { %>
    <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg px-2.5 py-1.5 mb-3">
      <p class="text-xs text-amber-400"><i class="fa-solid fa-note-sticky mr-1"></i><%= order.special_note %></p>
    </div>
  <% } %>

  <!-- Actions — use data attributes, JS handles clicks below -->
  <div class="flex gap-2 flex-wrap">

    <% if (ns) { %>
      <button
        data-action="advance"
        data-order-id="<%= order.id %>"
        data-next-status="<%= ns %>"
        data-btn-color="<%= nc %>"
        class="text-white text-xs font-semibold px-3 py-2 rounded-lg flex-1 transition-colors <%= nc %>">
        <i class="fa-solid fa-arrow-right mr-1"></i><%= nl %>
      </button>
    <% } else { %>
      <span class="bg-gray-700 opacity-50 text-white text-xs font-semibold px-3 py-2 rounded-lg flex-1 text-center">
        <i class="fa-solid fa-check mr-1"></i><%= nl %>
      </span>
    <% } %>

    <% if (isReady && hasPhone) { %>
      <button
        data-action="sms"
        data-order-id="<%= order.id %>"
        class="bg-orange-500 hover:bg-orange-600 text-white text-xs font-semibold px-3 py-2 rounded-lg transition-colors">
        <i class="fa-solid fa-message mr-1"></i>Notify
      </button>
    <% } %>

    <a href="/admin/bill/<%= order.uuid %>" target="_blank"
      class="bg-gray-700 hover:bg-gray-600 text-white text-xs font-semibold px-3 py-2 rounded-lg transition-colors">
      <i class="fa-solid fa-print"></i>
    </a>

  </div>
</div>

<!-- views/admin/order-card.ejs — reusable order card for dashboard columns -->
<div class="bg-gray-900 border border-gray-800 rounded-2xl p-4 hover:border-gray-700 transition-colors" id="order-<%= order.id %>">

  <!-- Order header -->
  <div class="flex items-center justify-between mb-3">
    <div>
      <div class="flex items-center gap-2">
        <span class="font-mono font-bold text-white text-sm">#<%= order.uuid.slice(0,8).toUpperCase() %></span>
        <% if (order.priority === 'high') { %>
          <span class="bg-purple-500/20 text-purple-400 text-[10px] font-bold px-1.5 py-0.5 rounded-full flex items-center gap-0.5">
            <i class="fa-solid fa-star text-[8px]"></i>PRIORITY
          </span>
        <% } %>
      </div>
      <p class="text-xs text-gray-400 mt-0.5">
        <%= new Date(order.created_at).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %>
      </p>
    </div>
    <span class="font-bold text-orange-400">₹<%= parseFloat(order.total_amount).toFixed(0) %></span>
  </div>

  <!-- Customer info -->
  <div class="bg-gray-800 rounded-xl px-3 py-2.5 mb-3">
    <div class="flex items-center gap-2">
      <div class="w-6 h-6 bg-orange-500/20 rounded-full flex items-center justify-center flex-shrink-0">
        <i class="fa-solid fa-user text-orange-400 text-[10px]"></i>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-medium text-white truncate"><%= order.user_name %></p>
        <p class="text-xs text-gray-400 truncate"><%= order.user_phone || 'No phone' %></p>
      </div>
      <% if (order.user_role === 'lecturer') { %>
        <span class="ml-auto text-[10px] bg-purple-500/20 text-purple-400 px-1.5 py-0.5 rounded font-semibold flex-shrink-0">Staff</span>
      <% } %>
    </div>
  </div>

  <!-- Items -->
  <div class="space-y-1 mb-3">
    <% (order.items || []).forEach(item => { %>
      <div class="flex justify-between text-xs text-gray-400">
        <span class="truncate"><%= item.item_name %></span>
        <span class="ml-2 flex-shrink-0">× <%= item.quantity %></span>
      </div>
    <% }) %>
  </div>

  <!-- Special note -->
  <% if (order.special_note) { %>
    <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg px-2.5 py-1.5 mb-3">
      <p class="text-xs text-amber-400"><i class="fa-solid fa-note-sticky mr-1"></i><%= order.special_note %></p>
    </div>
  <% } %>

  <!-- Action buttons -->
  <div class="flex gap-2 flex-wrap">
    <!-- Status advance button -->
    <button onclick="updateStatus(<%= order.id %>, '<%= nextStatus %>')"
      class="<%= nextColor %> text-white text-xs font-semibold px-3 py-2 rounded-lg flex-1 transition-colors">
      <i class="fa-solid fa-arrow-right mr-1"></i><%= nextLabel %>
    </button>

    <!-- SMS notify button (only for ready orders) -->
    <% if (order.status === 'ready' && order.user_phone) { %>
      <button onclick="sendSMS(<%= order.id %>)"
        class="bg-orange-500 hover:bg-orange-600 text-white text-xs font-semibold px-3 py-2 rounded-lg transition-colors">
        <i class="fa-solid fa-message mr-1"></i>Notify
      </button>
    <% } %>

    <!-- Print bill button -->
    <a href="/admin/bill/<%= order.uuid %>" target="_blank"
      class="bg-gray-700 hover:bg-gray-600 text-white text-xs font-semibold px-3 py-2 rounded-lg transition-colors">
      <i class="fa-solid fa-print"></i>
    </a>
  </div>
</div>

<%- include('../partials/header', { title: 'Admin Login' }) %>

<div class="min-h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-orange-950 flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-white/10 backdrop-blur-sm rounded-3xl p-8 border border-white/20 animate-slide-up">

      <!-- Header -->
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-orange-500 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-warm">
          <i class="fa-solid fa-store text-white text-2xl"></i>
        </div>
        <h1 class="font-display text-3xl font-bold text-white">Stall Admin</h1>
        <p class="text-gray-400 text-sm mt-1">Sign in to manage your stall</p>
      </div>

      <!-- Error -->
      <div id="auth-error" class="hidden bg-red-500/20 border border-red-500/40 text-red-300 text-sm rounded-xl px-4 py-3 mb-5 flex items-center gap-2">
        <i class="fa-solid fa-circle-exclamation flex-shrink-0"></i>
        <span id="auth-error-msg"></span>
      </div>

      <!-- Form -->
      <div class="space-y-4">
        <div class="relative">
          <i class="fa-solid fa-store absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
          <input type="text" id="stall-name" placeholder="Stall name (e.g. RHK Meals & Snacks)"
            class="w-full pl-11 pr-4 py-3.5 bg-white/10 border border-white/20 text-white placeholder-gray-500 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
        </div>

        <div class="relative">
          <i class="fa-solid fa-phone absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
          <input type="tel" id="admin-phone" placeholder="Registered mobile number"
            maxlength="10"
            class="w-full pl-11 pr-4 py-3.5 bg-white/10 border border-white/20 text-white placeholder-gray-500 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
        </div>

        <div class="relative">
          <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
          <input type="password" id="admin-password" placeholder="Password"
            class="w-full pl-11 pr-11 py-3.5 bg-white/10 border border-white/20 text-white placeholder-gray-500 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
          <button type="button" onclick="togglePwd()" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white">
            <i id="eye-icon" class="fa-solid fa-eye text-sm"></i>
          </button>
        </div>
      </div>

      <button id="login-btn" onclick="doLogin()"
        class="w-full mt-6 bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-white py-3.5 rounded-2xl font-semibold text-sm transition-all flex items-center justify-center gap-2">
        <i class="fa-solid fa-right-to-bracket"></i> Sign In
      </button>

    </div>

    <div class="text-center mt-5">
      <a href="/" class="text-sm text-gray-500 hover:text-white transition-colors">
        <i class="fa-solid fa-arrow-left mr-1.5"></i>Back to main site
      </a>
    </div>
  </div>
</div>

<script>
  function showError(msg) {
    document.getElementById('auth-error-msg').textContent = msg;
    document.getElementById('auth-error').classList.remove('hidden');
    document.getElementById('auth-error').classList.add('flex');
  }

  function togglePwd() {
    const input = document.getElementById('admin-password');
    const icon  = document.getElementById('eye-icon');
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    icon.className = `fa-solid fa-eye${isText ? '' : '-slash'} text-sm`;
  }

  async function doLogin() {
    const stall_name = document.getElementById('stall-name').value.trim();
    const phone      = document.getElementById('admin-phone').value.trim();
    const password   = document.getElementById('admin-password').value;

    if (!stall_name) { showError('Please enter your stall name.'); return; }
    if (!phone || !/^[6-9]\d{9}$/.test(phone)) { showError('Enter a valid 10-digit mobile number.'); return; }
    if (!password) { showError('Please enter your password.'); return; }

    const btn = document.getElementById('login-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Signing in...';

    try {
      const res  = await fetch('/admin/verify-phone', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ stall_name, phone, password }),
      });
      const data = await res.json();

      if (!data.success) {
        showError(data.error || 'Login failed.');
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-right-to-bracket"></i> Sign In';
        return;
      }

      btn.innerHTML = `<i class="fa-solid fa-circle-check"></i> Welcome, ${data.stallName}!`;
      setTimeout(() => window.location.href = '/admin/dashboard', 800);
    } catch {
      showError('Network error. Please try again.');
      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-right-to-bracket"></i> Sign In';
    }
  }

  document.getElementById('admin-password').addEventListener('keydown', e => {
    if (e.key === 'Enter') doLogin();
  });
</script>
</body>
</html>

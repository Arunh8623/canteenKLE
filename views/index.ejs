<%- include('partials/header', { title: 'Home' }) %>
<%- include('partials/navbar') %>

<main class="flex-1">

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-orange-600 via-orange-500 to-amber-400 overflow-hidden">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-8 left-12 text-8xl">🍛</div>
      <div class="absolute top-16 right-24 text-7xl">🥗</div>
      <div class="absolute bottom-8 left-1/4 text-6xl">🧃</div>
      <div class="absolute bottom-12 right-16 text-8xl">🍜</div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white text-sm font-medium px-4 py-2 rounded-full mb-6 border border-white/30">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        Pre-order now · Skip the queue
      </div>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-4 leading-tight">
        Campus Canteen,<br/>
        <span class="text-amber-200">At Your Fingertips</span>
      </h1>
      <p class="text-orange-100 text-lg sm:text-xl max-w-2xl mx-auto mb-8">
        Order during class hours. Walk in during your 15-minute break.
        Your food is hot and ready — no queue, no waiting.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">

        <!-- Browse Canteens — white filled button -->
        <a href="#canteens"
          style="display:inline-flex;align-items:center;justify-content:center;background:white;color:#ea580c;font-weight:600;padding:0.75rem 1.5rem;border-radius:0.75rem;font-size:1rem;text-decoration:none;transition:all 0.2s;box-shadow:0 10px 25px rgba(0,0,0,0.2);"
          onmouseover="this.style.background='#fff7ed'" onmouseout="this.style.background='white'">
          <i class="fa-solid fa-store mr-2"></i>Browse Canteens
        </a>

        <!-- Login / My Orders — white outline button -->
        <% if (!user) { %>
          <a href="/auth/login"
            style="display:inline-flex;align-items:center;justify-content:center;background:transparent;color:white;font-weight:600;padding:0.75rem 1.5rem;border-radius:0.75rem;font-size:1rem;text-decoration:none;border:2px solid white;transition:all 0.2s;"
            onmouseover="this.style.background='rgba(255,255,255,0.15)'" onmouseout="this.style.background='transparent'">
            <i class="fa-brands fa-google mr-2"></i>Login with KLE Email
          </a>
        <% } else { %>
          <a href="/order/my-orders"
            style="display:inline-flex;align-items:center;justify-content:center;background:transparent;color:white;font-weight:600;padding:0.75rem 1.5rem;border-radius:0.75rem;font-size:1rem;text-decoration:none;border:2px solid white;transition:all 0.2s;"
            onmouseover="this.style.background='rgba(255,255,255,0.15)'" onmouseout="this.style.background='transparent'">
            <i class="fa-solid fa-receipt mr-2"></i>My Orders
          </a>
        <% } %>

      </div>
    </div>

    <!-- Wave divider -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" class="fill-amber-50 w-full">
        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z"/>
      </svg>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="text-center mb-10">
      <h2 class="font-display text-3xl font-bold text-gray-900">How It Works</h2>
      <p class="text-gray-500 mt-2">Three easy steps to a queue-free meal</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <% const steps = [
        { icon: 'fa-magnifying-glass', num: '01', color: 'bg-blue-50 text-blue-500', title: 'Browse Menu', desc: 'Explore canteens and stalls. Browse full menus without logging in.' },
        { icon: 'fa-cart-plus', num: '02', color: 'bg-orange-50 text-orange-500', title: 'Place Order', desc: 'Add items to cart and pay securely via Razorpay during class hours.' },
        { icon: 'fa-bell', num: '03', color: 'bg-green-50 text-green-500', title: 'Collect & Eat', desc: 'Get an SMS when your order is ready. Walk in and pick it up — zero wait.' },
      ] %>
      <% steps.forEach(s => { %>
        <div class="card p-6 text-center group hover:shadow-warm transition-all duration-300">
          <div class="w-14 h-14 <%= s.color %> rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
            <i class="fa-solid <%= s.icon %> text-xl"></i>
          </div>
          <div class="text-xs font-bold text-gray-300 mb-1 font-mono"><%= s.num %></div>
          <h3 class="font-display font-bold text-gray-900 text-lg mb-2"><%= s.title %></h3>
          <p class="text-sm text-gray-500 leading-relaxed"><%= s.desc %></p>
        </div>
      <% }) %>
    </div>
  </section>

  <!-- Canteens Section -->
  <section id="canteens" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="text-center mb-10">
      <h2 class="font-display text-3xl font-bold text-gray-900">Our Canteens</h2>
      <p class="text-gray-500 mt-2">Two great options on campus</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <% canteens.forEach(canteen => { %>
        <a href="/canteen/<%= canteen.id %>" class="card-hover group">
          <!-- Image -->
          <div class="relative overflow-hidden h-52">
            <img src="<%= canteen.image_url || '/images/canteen-default.jpg' %>"
              alt="<%= canteen.name %>"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              onerror="this.src='/images/canteen-default.jpg'" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            <!-- Open badge -->
            <div class="absolute top-3 right-3 bg-green-400 text-white text-xs font-bold px-2.5 py-1 rounded-full flex items-center gap-1">
              <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span> Open
            </div>
            <h3 class="absolute bottom-4 left-4 font-display font-bold text-white text-2xl"><%= canteen.name %></h3>
          </div>
          <!-- Info -->
          <div class="p-5">
            <p class="text-gray-600 text-sm leading-relaxed mb-4"><%= canteen.description %></p>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-1.5 text-xs text-gray-500">
                <i class="fa-solid fa-location-dot text-orange-400"></i>
                <span><%= canteen.location %></span>
              </div>
              <span class="flex items-center gap-1.5 text-orange-600 font-semibold text-sm group-hover:gap-2.5 transition-all">
                View Menu <i class="fa-solid fa-arrow-right text-xs"></i>
              </span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  </section>

  <!-- Role info banner -->
  <section class="bg-gradient-to-r from-purple-50 to-orange-50 border-y border-purple-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="text-center mb-6">
        <h2 class="font-display text-2xl font-bold text-gray-900">Priority Ordering for Staff</h2>
        <p class="text-gray-500 mt-1 text-sm">Lecturer orders are automatically given priority in the queue</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl p-5 border border-blue-100 shadow-sm flex items-center gap-4">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-graduation-cap text-blue-500 text-xl"></i>
          </div>
          <div>
            <p class="font-semibold text-gray-900">Students</p>
            <p class="text-xs text-gray-500">usn@kletech.ac.in</p>
            <p class="text-xs text-blue-600 mt-0.5 font-medium">Standard queue priority</p>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-5 border border-purple-100 shadow-sm flex items-center gap-4">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-chalkboard-user text-purple-500 text-xl"></i>
          </div>
          <div>
            <p class="font-semibold text-gray-900">Lecturers & Staff</p>
            <p class="text-xs text-gray-500">name.surname@kletech.ac.in</p>
            <p class="text-xs text-purple-600 mt-0.5 font-medium">⭐ High-priority queue</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
</body>
</html>

<%- include('../partials/header', { title: 'Login' }) %>

<div class="min-h-screen bg-gradient-to-br from-orange-50 via-amber-50 to-white flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="card p-8 animate-slide-up">

      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-gradient-to-br from-orange-500 to-amber-400 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-warm">
          <i class="fa-solid fa-utensils text-white text-2xl"></i>
        </div>
        <h1 class="font-display text-3xl font-bold text-gray-900">KLE Canteen</h1>
        <p class="text-gray-500 text-sm mt-1">Sign in to start ordering</p>
      </div>

      <!-- Error -->
      <div id="auth-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3 mb-5 flex items-center gap-2">
        <i class="fa-solid fa-circle-exclamation flex-shrink-0"></i>
        <span id="auth-error-msg"></span>
      </div>

      <!-- Tabs -->
      <div class="flex bg-gray-100 rounded-2xl p-1 mb-6">
        <button id="tab-login" onclick="switchTab('login')"
          class="flex-1 py-2.5 rounded-xl text-sm font-semibold transition-all bg-white text-orange-600 shadow-sm">
          Sign In
        </button>
        <button id="tab-register" onclick="switchTab('register')"
          class="flex-1 py-2.5 rounded-xl text-sm font-semibold transition-all text-gray-500">
          Register
        </button>
      </div>

      <!-- LOGIN FORM -->
      <div id="form-login">
        <div class="space-y-4">
          <div class="relative">
            <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="email" id="login-email" placeholder="your@kletech.ac.in"
              class="w-full pl-11 pr-4 py-3.5 border-2 border-gray-200 rounded-2xl text-sm focus:outline-none focus:border-orange-400 transition-colors"
              autocomplete="email" />
          </div>
          <div class="relative">
            <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="password" id="login-password" placeholder="Password"
              class="w-full pl-11 pr-11 py-3.5 border-2 border-gray-200 rounded-2xl text-sm focus:outline-none focus:border-orange-400 transition-colors"
              autocomplete="current-password" />
            <button type="button" onclick="togglePwd('login-password', this)" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
              <i class="fa-solid fa-eye text-sm"></i>
            </button>
          </div>
        </div>

        <button id="login-btn" onclick="doLogin()"
          class="w-full mt-5 bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-white py-3.5 rounded-2xl font-semibold text-sm transition-all shadow-warm flex items-center justify-center gap-2">
          <i class="fa-solid fa-right-to-bracket"></i> Sign In
        </button>

        <p class="text-center text-xs text-gray-400 mt-4">
          Don't have an account?
          <button onclick="switchTab('register')" class="text-orange-500 font-semibold hover:text-orange-700">Register here</button>
        </p>
      </div>

      <!-- REGISTER FORM -->
      <div id="form-register" class="hidden">
        <div class="space-y-3">
          <div class="relative">
            <i class="fa-solid fa-user absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="text" id="reg-name" placeholder="Full name"
              class="w-full pl-11 pr-4 py-3.5 border-2 border-gray-200 rounded-2xl text-sm focus:outline-none focus:border-orange-400 transition-colors" />
          </div>
          <div class="relative">
            <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="email" id="reg-email" placeholder="your@kletech.ac.in"
              class="w-full pl-11 pr-4 py-3.5 border-2 border-gray-200 rounded-2xl text-sm focus:outline-none focus:border-orange-400 transition-colors" />
          </div>
          <div class="relative">
            <i class="fa-solid fa-phone absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="tel" id="reg-phone" placeholder="Mobile number (for order alerts)"
              class="w-full pl-11 pr-4 py-3.5 border-2 border-gray-200 rounded-2xl text-sm focus:outline-none focus:border-orange-400 transition-colors"
              maxlength="10" />
          </div>
          <div class="relative">
            <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="password" id="reg-password" placeholder="Create a password (min 6 chars)"
              class="w-full pl-11 pr-11 py-3.5 border-2 border-gray-200 rounded-2xl text-sm focus:outline-none focus:border-orange-400 transition-colors" />
            <button type="button" onclick="togglePwd('reg-password', this)" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
              <i class="fa-solid fa-eye text-sm"></i>
            </button>
          </div>
        </div>

        <!-- Email hint -->
        <div class="flex gap-2 mt-3">
          <div class="flex-1 bg-blue-50 rounded-xl p-2.5 flex items-center gap-2">
            <i class="fa-solid fa-graduation-cap text-blue-500 text-xs"></i>
            <p class="text-xs text-blue-600 font-mono">01fe24bci106@kletech.ac.in</p>
          </div>
          <div class="flex-1 bg-purple-50 rounded-xl p-2.5 flex items-center gap-2">
            <i class="fa-solid fa-chalkboard-user text-purple-500 text-xs"></i>
            <p class="text-xs text-purple-600 font-mono">name.surname@kletech.ac.in</p>
          </div>
        </div>

        <button id="register-btn" onclick="doRegister()"
          class="w-full mt-4 bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-white py-3.5 rounded-2xl font-semibold text-sm transition-all shadow-warm flex items-center justify-center gap-2">
          <i class="fa-solid fa-user-plus"></i> Create Account
        </button>

        <p class="text-center text-xs text-gray-400 mt-4">
          Already have an account?
          <button onclick="switchTab('login')" class="text-orange-500 font-semibold hover:text-orange-700">Sign in</button>
        </p>
      </div>

      <!-- DEV ONLY -->
      <div class="mt-6 pt-5 border-t border-dashed border-gray-200">
        <p class="text-center text-xs text-orange-500 font-semibold mb-3">⚙️ Dev Mode — Quick Login</p>
        <form action="/auth/dummy-login" method="POST" class="flex gap-2">
          <input type="email" name="email" placeholder="your@kletech.ac.in"
            class="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-orange-400" required />
          <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-xl text-sm font-semibold">Login</button>
        </form>
      </div>

    </div>

    <div class="text-center mt-5">
      <a href="/" class="text-sm text-gray-500 hover:text-orange-600 transition-colors">
        <i class="fa-solid fa-arrow-left mr-1.5"></i>Browse menu without logging in
      </a>
    </div>
  </div>
</div>

<script>
  function switchTab(tab) {
    const isLogin = tab === 'login';
    document.getElementById('form-login').classList.toggle('hidden', !isLogin);
    document.getElementById('form-register').classList.toggle('hidden', isLogin);
    document.getElementById('tab-login').className = `flex-1 py-2.5 rounded-xl text-sm font-semibold transition-all ${isLogin ? 'bg-white text-orange-600 shadow-sm' : 'text-gray-500'}`;
    document.getElementById('tab-register').className = `flex-1 py-2.5 rounded-xl text-sm font-semibold transition-all ${!isLogin ? 'bg-white text-orange-600 shadow-sm' : 'text-gray-500'}`;
    hideError();
  }

  function showError(msg) {
    document.getElementById('auth-error-msg').textContent = msg;
    document.getElementById('auth-error').classList.remove('hidden');
    document.getElementById('auth-error').classList.add('flex');
  }

  function hideError() {
    document.getElementById('auth-error').classList.add('hidden');
  }

  function togglePwd(id, btn) {
    const input = document.getElementById(id);
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    btn.innerHTML = `<i class="fa-solid fa-eye${isText ? '' : '-slash'} text-sm"></i>`;
  }

  function setLoading(btnId, loading, defaultHTML) {
    const btn = document.getElementById(btnId);
    btn.disabled = loading;
    btn.innerHTML = loading ? '<i class="fa-solid fa-spinner fa-spin"></i> Please wait...' : defaultHTML;
  }

  async function doLogin() {
    hideError();
    const email    = document.getElementById('login-email').value.trim().toLowerCase();
    const password = document.getElementById('login-password').value;

    if (!email || !email.endsWith('@kletech.ac.in')) { showError('Only @kletech.ac.in emails are allowed.'); return; }
    if (!password) { showError('Please enter your password.'); return; }

    setLoading('login-btn', true);
    try {
      const res  = await fetch('/auth/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, password }) });
      const data = await res.json();
      if (!data.success) { showError(data.error); setLoading('login-btn', false, '<i class="fa-solid fa-right-to-bracket"></i> Sign In'); return; }
      window.location.href = '/';
    } catch { showError('Network error. Please try again.'); setLoading('login-btn', false, '<i class="fa-solid fa-right-to-bracket"></i> Sign In'); }
  }

  async function doRegister() {
    hideError();
    const name     = document.getElementById('reg-name').value.trim();
    const email    = document.getElementById('reg-email').value.trim().toLowerCase();
    const phone    = document.getElementById('reg-phone').value.trim();
    const password = document.getElementById('reg-password').value;

    if (!name)  { showError('Please enter your full name.'); return; }
    if (!email || !email.endsWith('@kletech.ac.in')) { showError('Only @kletech.ac.in emails are allowed.'); return; }
    if (!phone || !/^[6-9]\d{9}$/.test(phone)) { showError('Enter a valid 10-digit mobile number.'); return; }
    if (!password || password.length < 6) { showError('Password must be at least 6 characters.'); return; }

    setLoading('register-btn', true);
    try {
      const res  = await fetch('/auth/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, email, phone, password }) });
      const data = await res.json();
      if (!data.success) { showError(data.error); setLoading('register-btn', false, '<i class="fa-solid fa-user-plus"></i> Create Account'); return; }
      window.location.href = '/';
    } catch { showError('Network error. Please try again.'); setLoading('register-btn', false, '<i class="fa-solid fa-user-plus"></i> Create Account'); }
  }

  // Enter key support
  document.getElementById('login-password').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });

  // Check for error in URL
  const urlError = new URLSearchParams(window.location.search).get('error');
  if (urlError) showError(urlError);
</script>

</body>
</html>

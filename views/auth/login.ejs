<%- include('../partials/header', { title: 'Login' }) %>

<div class="min-h-screen bg-gradient-to-br from-orange-50 via-amber-50 to-white flex items-center justify-center p-4">
  <div class="w-full max-w-md">

    <!-- Card -->
    <div class="card p-8 animate-slide-up">

      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-gradient-to-br from-orange-500 to-amber-400 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-warm">
          <i class="fa-solid fa-utensils text-white text-2xl"></i>
        </div>
        <h1 class="font-display text-3xl font-bold text-gray-900">KLE Canteen</h1>
        <p class="text-gray-500 text-sm mt-1">Sign in to start ordering</p>
      </div>

      <!-- Error message -->
      <div id="auth-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3 mb-5 flex items-center gap-2">
        <i class="fa-solid fa-circle-exclamation flex-shrink-0"></i>
        <span id="auth-error-msg"></span>
      </div>

      <!-- Google sign-in button -->
      <button id="google-btn" onclick="signInWithGoogle()"
        class="w-full flex items-center justify-center gap-3 border-2 border-gray-200 hover:border-orange-300 hover:bg-orange-50 py-3.5 rounded-2xl font-semibold text-gray-700 transition-all duration-200 group">
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <span>Continue with Google</span>
        <i class="fa-solid fa-arrow-right text-sm text-gray-400 group-hover:text-orange-500 group-hover:translate-x-1 transition-all"></i>
      </button>

      <!-- Divider -->
      <div class="flex items-center gap-3 my-6">
        <div class="flex-1 h-px bg-gray-100"></div>
        <p class="text-xs text-gray-400 font-medium">KLE email only</p>
        <div class="flex-1 h-px bg-gray-100"></div>
      </div>

      <!-- Email format info -->
      <div class="space-y-2">
        <div class="bg-blue-50 rounded-xl p-3.5 flex items-center gap-3">
          <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-graduation-cap text-blue-500 text-xs"></i>
          </div>
          <div>
            <p class="text-xs font-semibold text-blue-800">Students</p>
            <p class="text-xs text-blue-600 font-mono mt-0.5">01fe24bci106@kletech.ac.in</p>
          </div>
        </div>
        <div class="bg-purple-50 rounded-xl p-3.5 flex items-center gap-3">
          <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-chalkboard-user text-purple-500 text-xs"></i>
          </div>
          <div>
            <p class="text-xs font-semibold text-purple-800">Lecturers & Staff <span class="ml-1 bg-purple-200 text-purple-800 px-1.5 py-0.5 rounded-full text-[10px] font-bold">Priority Queue</span></p>
            <p class="text-xs text-purple-600 font-mono mt-0.5">prakash.hegde@kletech.ac.in</p>
          </div>
        </div>
      </div>

      <p class="text-center text-xs text-gray-400 mt-6">
        By logging in you agree to our terms. <br/>
        Only @kletech.ac.in email addresses are accepted.
      </p>

      <!-- DEV ONLY: Dummy login -->
      <div class="mt-6 pt-6 border-t border-dashed border-gray-200">
        <p class="text-center text-xs text-orange-500 font-semibold mb-3">⚙️ Dev Mode — Quick Login</p>
        <% if (locals.error) { %>
          <p class="text-red-500 text-xs text-center mb-2"><%= error %></p>
        <% } %>
        <form action="/auth/dummy-login" method="POST" class="flex gap-2">
          <input type="email" name="email" placeholder="your@kletech.ac.in"
            class="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-orange-400"
            required />
          <button type="submit"
            class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-xl text-sm font-semibold transition-colors">
            Login
          </button>
        </form>
      </div>
    </div>

    <!-- Back to browse -->
    <div class="text-center mt-5">
      <a href="/" class="text-sm text-gray-500 hover:text-orange-600 transition-colors">
        <i class="fa-solid fa-arrow-left mr-1.5"></i>Browse menu without logging in
      </a>
    </div>
  </div>
</div>

<!-- Firebase Client SDK -->
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-auth-compat.js"></script>
<script>
  firebase.initializeApp({
    apiKey:            "<%= firebaseConfig.apiKey %>",
    authDomain:        "<%= firebaseConfig.authDomain %>",
    storageBucket:     "<%= firebaseConfig.storageBucket %>",
    messagingSenderId: "<%= firebaseConfig.messagingSenderId %>",
    appId:             "<%= firebaseConfig.appId %>",
  });

  const auth     = firebase.auth();
  // NOTE: removed hd restriction — it was causing popup to close prematurely on college accounts
  const provider = new firebase.auth.GoogleAuthProvider();
  provider.addScope('email');
  provider.addScope('profile');

  function showError(msg) {
    document.getElementById('auth-error-msg').textContent = msg;
    document.getElementById('auth-error').classList.remove('hidden');
    document.getElementById('auth-error').classList.add('flex');
  }
  function showLoading() {
    document.getElementById('google-btn').disabled = true;
    document.getElementById('google-btn').innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Signing in...';
  }
  function resetBtn() {
    document.getElementById('google-btn').disabled = false;
    document.getElementById('google-btn').innerHTML = '<svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg><span>Continue with Google</span>';
  }

  async function verifyWithServer(user) {
    try {
      const idToken = await user.getIdToken(true);
      const res = await fetch('/auth/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idToken }),
      });
      const data = await res.json();
      console.log('Server response:', res.status, data);
      if (!res.ok) {
        await auth.signOut();
        showError(data.error || 'Login failed');
        resetBtn();
        return;
      }
      window.location.href = '/';
    } catch(err) {
      await auth.signOut();
      showError(err.message || 'Login failed');
      resetBtn();
    }
  }

  async function signInWithGoogle() {
    showLoading();
    try {
      // signInWithPopup — most reliable for localhost
      const result = await auth.signInWithPopup(provider);
      console.log('Popup success:', result.user.email);
      await verifyWithServer(result.user);
    } catch(err) {
      console.log('Popup error:', err.code, err.message);
      resetBtn();
      if (err.code === 'auth/popup-closed-by-user') {
        showError('Sign-in cancelled. Please try again and complete all Google steps.');
      } else if (err.code === 'auth/popup-blocked') {
        showError('Popup was blocked by browser. Please allow popups for localhost:3000 and try again.');
      } else {
        showError(err.message || 'Login failed');
      }
    }
  }
</script>
</body>
</html>

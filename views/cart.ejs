<%- include('partials/header', { title: 'Your Cart' }) %>
<%- include('partials/navbar') %>

<main class="flex-1 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex items-center gap-3 mb-8">
    <a href="javascript:history.back()" class="text-gray-400 hover:text-orange-600 transition-colors">
      <i class="fa-solid fa-arrow-left text-xl"></i>
    </a>
    <h1 class="font-display text-3xl font-bold text-gray-900">Your Cart</h1>
    <% if (items.length > 0) { %>
      <span class="bg-orange-100 text-orange-700 text-sm font-semibold px-3 py-1 rounded-full">
        <%= items.reduce((s,i) => s + i.quantity, 0) %> items
      </span>
    <% } %>
  </div>

  <% if (items.length === 0) { %>
    <!-- Empty cart -->
    <div class="text-center py-20">
      <div class="w-20 h-20 bg-orange-50 rounded-full flex items-center justify-center mx-auto mb-5">
        <i class="fa-solid fa-cart-shopping text-orange-300 text-3xl"></i>
      </div>
      <h2 class="font-display text-2xl font-bold text-gray-900 mb-2">Your cart is empty</h2>
      <p class="text-gray-500 mb-6">Add some delicious items from our canteens!</p>
      <a href="/" class="btn-primary">Browse Canteens</a>
    </div>

  <% } else { %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Cart Items -->
      <div class="lg:col-span-2 space-y-3">
        <!-- Stall info banner -->
        <div class="bg-orange-50 border border-orange-200 rounded-2xl px-4 py-3 flex items-center gap-3">
          <i class="fa-solid fa-store text-orange-500"></i>
          <div>
            <p class="text-sm font-semibold text-gray-800">Ordering from: <span class="text-orange-600"><%= items[0].stall_name %></span></p>
            <p class="text-xs text-gray-500">All items must be from the same stall</p>
          </div>
          <a href="/stall/<%= items[0].stall_id %>" class="ml-auto text-xs text-orange-600 hover:underline">+ Add more</a>
        </div>

        <!-- Items list -->
        <div id="cart-items-list" class="space-y-3">
          <% items.forEach(item => { %>
            <div class="card p-4 flex items-center gap-4" id="cart-row-<%= item.menu_item_id %>">
              <% if (item.image_url) { %>
                <img src="<%= item.image_url %>" alt="<%= item.name %>"
                  class="w-16 h-16 rounded-xl object-cover flex-shrink-0" />
              <% } else { %>
                <div class="w-16 h-16 rounded-xl bg-orange-50 flex items-center justify-center flex-shrink-0">
                  <i class="fa-solid fa-utensils text-orange-300 text-xl"></i>
                </div>
              <% } %>

              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-gray-900 truncate"><%= item.name %></h3>
                <p class="text-sm text-gray-500">₹<%= parseFloat(item.price).toFixed(0) %> each</p>
              </div>

              <!-- Qty controls -->
              <div class="flex items-center gap-2">
                <button onclick="updateCartItem(<%= item.menu_item_id %>, <%= item.quantity - 1 %>)"
                  class="w-8 h-8 bg-gray-100 hover:bg-red-100 hover:text-red-500 text-gray-600 rounded-full flex items-center justify-center font-bold text-lg transition-colors">−</button>
                <span class="font-bold text-gray-900 w-6 text-center" id="qty-<%= item.menu_item_id %>"><%= item.quantity %></span>
                <button onclick="updateCartItem(<%= item.menu_item_id %>, <%= item.quantity + 1 %>)"
                  class="w-8 h-8 bg-orange-100 hover:bg-orange-200 text-orange-700 rounded-full flex items-center justify-center font-bold text-lg transition-colors">+</button>
              </div>

              <!-- Subtotal -->
              <div class="text-right flex-shrink-0 min-w-[60px]">
                <p class="font-bold text-orange-600" id="subtotal-<%= item.menu_item_id %>">₹<%= parseFloat(item.subtotal).toFixed(0) %></p>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Clear cart -->
        <button onclick="clearCart()" class="text-sm text-red-500 hover:text-red-700 flex items-center gap-1.5 transition-colors">
          <i class="fa-solid fa-trash-can"></i> Clear cart
        </button>

        <!-- AI Suggestions -->
        <% if (suggestions && suggestions.length > 0) { %>
          <div class="card p-5 border border-amber-200 bg-amber-50">
            <p class="font-semibold text-gray-800 mb-3 flex items-center gap-2">
              <i class="fa-solid fa-wand-magic-sparkles text-amber-500"></i> You might also like
            </p>
            <div class="flex flex-wrap gap-2">
              <% suggestions.forEach(s => { %>
                <button onclick="addSuggestion(<%= s.id %>)"
                  class="flex items-center gap-2 bg-white hover:bg-orange-50 border border-orange-200 rounded-xl px-3 py-2 text-sm transition-all hover:border-orange-400 group">
                  <span class="font-medium text-gray-800 group-hover:text-orange-700"><%= s.name %></span>
                  <span class="text-orange-600 font-semibold">₹<%= parseFloat(s.price).toFixed(0) %></span>
                  <i class="fa-solid fa-plus text-orange-400 text-xs"></i>
                </button>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Order Summary -->
      <div class="space-y-4">
        <div class="card p-6 sticky top-24">
          <h2 class="font-display font-bold text-xl text-gray-900 mb-5">Order Summary</h2>

          <div class="space-y-2 text-sm mb-4">
            <% items.forEach(item => { %>
              <div class="flex justify-between text-gray-600">
                <span><%= item.name %> × <%= item.quantity %></span>
                <span>₹<span id="summary-sub-<%= item.menu_item_id %>"><%= parseFloat(item.subtotal).toFixed(0) %></span></span>
              </div>
            <% }) %>
          </div>

          <div class="border-t border-gray-100 pt-4 space-y-2 mb-5">
            <div class="flex justify-between text-sm text-gray-600">
              <span>Subtotal</span>
              <span>₹<span id="summary-total"><%= total.toFixed(0) %></span></span>
            </div>
            <div class="flex justify-between text-sm text-gray-500">
              <span>Platform fee</span>
              <span class="text-green-600 font-medium">FREE</span>
            </div>
            <div class="flex justify-between font-bold text-gray-900 text-lg pt-2 border-t border-gray-100">
              <span>Total</span>
              <span class="text-orange-600">₹<span id="grand-total"><%= total.toFixed(0) %></span></span>
            </div>
          </div>

          <!-- Special note -->
          <textarea id="special-note" rows="2" placeholder="Any special requests? (optional)"
            class="input-field text-sm resize-none mb-4"></textarea>

          <!-- Role badge -->
          <% if (user.role === 'lecturer') { %>
            <div class="bg-purple-50 border border-purple-200 rounded-xl px-3 py-2.5 mb-4 flex items-center gap-2">
              <i class="fa-solid fa-star text-purple-500 text-sm"></i>
              <p class="text-xs font-semibold text-purple-700">Your order will get <span class="text-purple-900">priority queue</span> treatment</p>
            </div>
          <% } %>

          <!-- Pay button -->
          <button id="pay-btn" onclick="initiatePayment()"
            class="btn-primary w-full text-base py-3.5 flex items-center justify-center gap-2">
            <i class="fa-solid fa-lock text-sm"></i>
            Pay ₹<span id="pay-amount"><%= total.toFixed(0) %></span> Securely
          </button>

          <div class="flex items-center justify-center gap-2 mt-3">
            <img src="https://razorpay.com/favicon.ico" class="w-4 h-4" alt="Razorpay" />
            <p class="text-xs text-gray-400">Secured by Razorpay</p>
          </div>
        </div>
      </div>

    </div>
  <% } %>
</main>

<!-- Razorpay SDK -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
let currentTotal = <%= total %>;

async function updateCartItem(itemId, newQty) {
  if (newQty <= 0) {
    // Remove item
    const res  = await fetch('/cart/remove', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ menuItemId: itemId })
    });
    const data = await res.json();
    document.getElementById('cart-row-' + itemId)?.remove();
    if (window.updateCartBadge) window.updateCartBadge(data.cartCount);
    if (data.cartCount === 0) window.location.reload();
    else updateTotals();
    return;
  }
  const res  = await fetch('/cart/update', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ menuItemId: itemId, quantity: newQty })
  });
  const data = await res.json();
  document.getElementById('qty-' + itemId).textContent = newQty;
  if (window.updateCartBadge) window.updateCartBadge(data.cartCount);
  window.location.reload();   // simple reload to recalculate
}

async function clearCart() {
  if (!confirm('Clear your entire cart?')) return;
  await fetch('/cart/clear', { method: 'POST' });
  window.location.reload();
}

async function addSuggestion(itemId) {
  const res  = await fetch('/cart/add', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ menuItemId: itemId, quantity: 1 })
  });
  if (res.ok) window.location.reload();
}

async function initiatePayment() {
  const btn  = document.getElementById('pay-btn');
  btn.disabled = true;
  btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin mr-2"></i> Processing...`;

  try {
    // Step 1: create Razorpay order
    const res  = await fetch('/order/create-razorpay-order', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }
    });
    const data = await res.json();
    if (!res.ok) { alert(JSON.stringify(data)); btn.disabled = false; btn.innerHTML = `<i class="fa-solid fa-lock text-sm"></i> Pay ₹${currentTotal.toFixed(0)} Securely`; return; }

    // Step 2: open Razorpay checkout
    const options = {
      key:         data.keyId,
      amount:      data.amount,
      currency:    data.currency,
      name:        'KLE Campus Canteen',
      description: 'Food Order',
      order_id:    data.razorpayOrderId,
      prefill:     { name: data.user.name, email: data.user.email, contact: '+91' + data.user.phone },
      theme:       { color: '#f97316' },
      handler: async function(response) {
        // Step 3: confirm order on server
        const confirmRes = await fetch('/order/confirm', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            razorpayPaymentId: response.razorpay_payment_id,
            razorpayOrderId:   response.razorpay_order_id,
            razorpaySignature: response.razorpay_signature,
            specialNote:       document.getElementById('special-note').value,
          }),
        });
        const confirmData = await confirmRes.json();
        if (confirmData.success) {
          window.location.href = '/order/success/' + confirmData.orderUUID;
        } else {
          alert('Payment verified but order failed: ' + confirmData.error);
        }
      },
      modal: {
        ondismiss: () => {
          btn.disabled = false;
          btn.innerHTML = `<i class="fa-solid fa-lock text-sm"></i> Pay ₹${currentTotal.toFixed(0)} Securely`;
        }
      }
    };
    new Razorpay(options).open();
  } catch (e) {
    alert('Error: ' + e.message);
    btn.disabled = false;
    btn.innerHTML = `<i class="fa-solid fa-lock text-sm"></i> Pay ₹${currentTotal.toFixed(0)} Securely`;
  }
}
</script>

<%- include('partials/footer') %>
</body>
</html>

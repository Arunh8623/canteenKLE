<%- include('partials/header', { title: 'Order Confirmed!' }) %>
<%- include('partials/navbar') %>

<main class="flex-1 max-w-2xl mx-auto px-4 sm:px-6 py-10">

  <!-- Success header -->
  <div class="text-center mb-8 animate-slide-up">
    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <i class="fa-solid fa-circle-check text-green-500 text-4xl"></i>
    </div>
    <h1 class="font-display text-3xl font-bold text-gray-900">Order Confirmed!</h1>
    <p class="text-gray-500 mt-2">
      <% if (user.phone) { %>
        We'll send an SMS to <strong><%= user.phone %></strong> when your order is ready.
      <% } else { %>
        Visit the stall counter to collect your order.
      <% } %>
    </p>
  </div>

  <!-- Queue position card -->
  <% if (queuePos) { %>
    <div class="card p-5 mb-5 bg-gradient-to-r from-orange-50 to-amber-50 border border-orange-200">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600">Your position in queue</p>
          <p class="text-4xl font-display font-bold text-orange-600 mt-1">#<%= queuePos %></p>
          <% if (user.role === 'lecturer') { %>
            <span class="text-xs font-semibold text-purple-700 bg-purple-100 px-2 py-0.5 rounded-full mt-1 inline-block">
              ⭐ Priority Order
            </span>
          <% } %>
        </div>
        <div class="text-right">
          <p class="text-sm text-gray-500">Estimated time</p>
          <p class="text-2xl font-bold text-gray-900">~<%= queuePos * 5 %> min</p>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Bill card -->
  <div class="card overflow-hidden mb-5">
    <!-- Bill header -->
    <div class="bg-gray-900 text-white px-6 py-5">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center">
            <i class="fa-solid fa-utensils text-white text-sm"></i>
          </div>
          <div>
            <p class="font-bold text-white">KLE Campus Canteen</p>
            <p class="text-xs text-gray-400"><%= order.canteen_name %> · <%= order.stall_name %></p>
          </div>
        </div>
        <div class="text-right">
          <p class="text-xs text-gray-400">Bill No.</p>
          <p class="font-mono text-orange-400 font-bold text-sm">#<%= order.uuid.slice(0,8).toUpperCase() %></p>
        </div>
      </div>
      <div class="border-t border-white/10 pt-4 grid grid-cols-2 gap-4 text-sm">
        <div>
          <p class="text-gray-400 text-xs">Customer</p>
          <p class="font-medium"><%= order.user_name %></p>
          <p class="text-xs text-gray-400 font-mono truncate"><%= order.user_email %></p>
        </div>
        <div class="text-right">
          <p class="text-gray-400 text-xs">Date & Time</p>
          <p class="font-medium"><%= new Date(order.created_at).toLocaleDateString('en-IN') %></p>
          <p class="text-xs text-gray-400"><%= new Date(order.created_at).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %></p>
        </div>
      </div>
    </div>

    <!-- Order items -->
    <div class="p-5">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 text-xs font-semibold text-gray-400 uppercase tracking-wide">
            <th class="text-left pb-2">Item</th>
            <th class="text-center pb-2">Qty</th>
            <th class="text-right pb-2">Price</th>
            <th class="text-right pb-2">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% items.forEach(item => { %>
            <tr>
              <td class="py-2.5 font-medium text-gray-800"><%= item.item_name %></td>
              <td class="py-2.5 text-center text-gray-500"><%= item.quantity %></td>
              <td class="py-2.5 text-right text-gray-500">₹<%= parseFloat(item.price_at_order).toFixed(0) %></td>
              <td class="py-2.5 text-right font-semibold text-gray-900">₹<%= (item.quantity * item.price_at_order).toFixed(0) %></td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr class="border-t-2 border-gray-200">
            <td colspan="3" class="pt-3 font-bold text-gray-900">Total Amount</td>
            <td class="pt-3 text-right font-bold text-orange-600 text-lg">₹<%= parseFloat(order.total_amount).toFixed(0) %></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Payment info -->
    <div class="px-5 pb-5">
      <div class="bg-green-50 border border-green-200 rounded-xl px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <i class="fa-solid fa-circle-check text-green-500"></i>
          <span class="text-sm font-semibold text-green-800">Payment Successful</span>
        </div>
        <span class="text-xs font-mono text-green-600 truncate max-w-[160px]"><%= order.payment_id %></span>
      </div>
    </div>

    <!-- Status -->
    <div class="border-t border-gray-100 px-5 py-4 flex items-center justify-between bg-gray-50">
      <span class="text-sm text-gray-500 font-medium">Order Status</span>
      <span class="status-<%= order.status %> text-xs font-bold px-3 py-1 rounded-full capitalize">
        <% if (order.status === 'pending') { %><i class="fa-solid fa-hourglass-start mr-1"></i>
        <% } else if (order.status === 'preparing') { %><i class="fa-solid fa-fire mr-1"></i>
        <% } else if (order.status === 'ready') { %><i class="fa-solid fa-bell mr-1"></i>
        <% } %><%= order.status %>
      </span>
    </div>
  </div>

  <!-- Action buttons -->
  <div class="flex flex-col sm:flex-row gap-3">
    <a href="/order/track/<%= order.uuid %>" class="btn-primary flex-1 text-center">
      <i class="fa-solid fa-location-dot mr-2"></i>Track Order
    </a>
    <a href="/order/my-orders" class="btn-secondary flex-1 text-center">
      <i class="fa-solid fa-receipt mr-2"></i>My Orders
    </a>
    <a href="/" class="btn-ghost flex-1 text-center border border-gray-200">
      <i class="fa-solid fa-house mr-2"></i>Home
    </a>
  </div>

  <!-- Phone reminder -->
  <% if (!user.phone) { %>
    <div class="mt-5 card p-4 bg-amber-50 border border-amber-200">
      <div class="flex items-start gap-3">
        <i class="fa-solid fa-triangle-exclamation text-amber-500 mt-0.5"></i>
        <div>
          <p class="text-sm font-semibold text-amber-800">Add your phone number</p>
          <p class="text-xs text-amber-700 mt-0.5">You'll miss the SMS notification when your order is ready.</p>
          <button onclick="showPhoneModal()" class="mt-2 text-xs font-semibold text-amber-800 underline">Add now</button>
        </div>
      </div>
    </div>
  <% } %>
</main>

<!-- Real-time status update via socket -->
<script>
  const socket = io();
  socket.emit('join_user_room', '<%= user.id %>');

  socket.on('order_update', (data) => {
    if (data.uuid === '<%= order.uuid %>') {
      const badge = document.querySelector('.status-<%= order.status %>');
      if (badge) {
        badge.className = `status-${data.status} text-xs font-bold px-3 py-1 rounded-full capitalize`;
        badge.innerHTML = `<i class="fa-solid fa-${data.status === 'ready' ? 'bell' : 'fire'} mr-1"></i>${data.status}`;
      }
      if (data.status === 'ready') {
        document.querySelector('h1').textContent = '🔔 Your Order is Ready!';
      }
    }
  });
</script>

<%- include('partials/footer') %>
</body>
</html>

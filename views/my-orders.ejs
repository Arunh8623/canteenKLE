<%- include('partials/header', { title: 'My Orders' }) %>
<%- include('partials/navbar') %>

<main class="flex-1 max-w-3xl mx-auto px-4 sm:px-6 py-10">
  <h1 class="font-display text-3xl font-bold text-gray-900 mb-8">My Orders</h1>

  <% if (orders.length === 0) { %>
    <div class="text-center py-20">
      <div class="w-16 h-16 bg-orange-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <i class="fa-solid fa-receipt text-orange-300 text-2xl"></i>
      </div>
      <h2 class="font-display text-xl font-bold text-gray-800 mb-2">No orders yet</h2>
      <p class="text-gray-500 text-sm mb-6">Start ordering from one of our canteens!</p>
      <a href="/" class="btn-primary">Browse Canteens</a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% orders.forEach(order => { %>
        <div class="card p-5 hover:shadow-md transition-shadow">
          <div class="flex items-start justify-between gap-3 flex-wrap mb-3">
            <div>
              <p class="font-mono font-bold text-gray-900">#<%= order.uuid.slice(0,8).toUpperCase() %></p>
              <p class="text-sm text-gray-500 mt-0.5"><%= order.stall_name %> · <%= order.canteen_name %></p>
              <p class="text-xs text-gray-400 mt-0.5">
                <%= new Date(order.created_at).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>
                at <%= new Date(order.created_at).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %>
              </p>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
              <% if (order.priority === 'high') { %>
                <span class="text-xs bg-purple-100 text-purple-700 font-semibold px-2.5 py-1 rounded-full flex items-center gap-1">
                  <i class="fa-solid fa-star text-[10px]"></i>Priority
                </span>
              <% } %>
              <span class="status-<%= order.status %> text-xs font-bold px-3 py-1 rounded-full capitalize">
                <%= order.status %>
              </span>
              <span class="font-bold text-orange-600">₹<%= parseFloat(order.total_amount).toFixed(0) %></span>
            </div>
          </div>
          <div class="flex gap-2 flex-wrap">
            <a href="/order/track/<%= order.uuid %>" class="text-xs btn-primary py-1.5 px-3">
              <i class="fa-solid fa-location-dot mr-1"></i>Track
            </a>
            <a href="/order/success/<%= order.uuid %>" class="text-xs btn-secondary py-1.5 px-3">
              <i class="fa-solid fa-receipt mr-1"></i>View Bill
            </a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>
</body>
</html>
